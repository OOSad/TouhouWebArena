; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.

[application]

config/name="TouhouWebArena"
config/description="Touhou-09 inspired bullet hell game"
config/icon="res://icon.png"

[display]

window/size/width=1280
window/size/height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="forward_plus"
environment/default_environment="res://default_env.tres"

[input]

ui_accept={
"deadzone": 0.5,
"events": [ Object(InputEventKey,resource_local_to_scene=false,resource_path="",device=0,alt_pressed=false,shift_pressed=false,ctrl_pressed=false,meta_pressed=false,command_or_control_pressed=false,pressed=false,keycode=16777221,physical_keycode=0,unicode=0,key_label=0,echo=false,window_id=0) ]
}

[autoload]

Global="*res://Scripts/Global.gd"

[physics]

2d/physics_engine="godot_physics"

[audio]

default_bus_layout="res://default_bus_layout.tres"

[debug]

gdscript/warnings/unused_variable=false
gdscript/warnings/shadowed_variable=false